---
interface Props {
  tags: string[];
  baseUrl?: URL;
}

const { tags, baseUrl } = Astro.props;

function tagUrl(tag: string): string {
  if (baseUrl) {
    const params = new URLSearchParams(baseUrl.search);
    params.delete("focus");
    if (!params.getAll("tag").includes(tag)) {
      params.append("tag", tag);
    }
    const qs = params.toString();
    return "/codes" + (qs ? "?" + qs : "");
  }
  return "/codes?tag=" + encodeURIComponent(tag);
}
---

{tags.length > 0 && (
  <div class="flex flex-wrap gap-1.5">
    {tags.map((tag) => (
      <a href={tagUrl(tag)} class="inline-block rounded bg-gray-100 px-2 py-0.5 text-xs text-gray-700 hover:bg-gray-200 transition-colors">
        {tag}
      </a>
    ))}
  </div>
)}
