---
interface Props {
  value: number | null;
  label?: string;
  title: string;
}

const { value, label, title } = Astro.props;
---

{
  value != null && (
    <span
      class="font-mono text-[13px] font-medium text-gray-900 dark:text-gray-100 tabular-nums"
      title={title}
    >
      {label ? `${label} ${value}` : value}
    </span>
  )
}
