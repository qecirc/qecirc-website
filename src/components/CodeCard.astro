---
import TagList from "./TagList.astro";
import type { Code } from "../lib/queries";
import { formatCodeParams } from "../lib/queries";

interface Props {
  code: Code & { tags: string[] };
}

const { code } = Astro.props;
const { name, slug, description, tags } = code;
const params = formatCodeParams(code);
---

<a href={`/codes/${slug}`} class="block rounded border border-gray-200 p-4 hover:border-gray-400 transition-colors">
  <div class="flex items-baseline gap-2 mb-1">
    <h3 class="font-medium">{name}</h3>
    <span class="text-sm text-gray-500">{params}</span>
  </div>
  {description && <p class="text-sm text-gray-600 mb-2 line-clamp-2">{description}</p>}
  <TagList tags={tags} />
</a>
