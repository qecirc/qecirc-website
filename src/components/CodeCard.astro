---
import TagList from "./TagList.astro";
import type { CodeWithMeta } from "../types";
import { formatCodeParams } from "../lib/queries";

interface Props {
  code: CodeWithMeta;
  baseUrl?: URL;
}

const { code, baseUrl } = Astro.props;
const { name, slug, tags, circuit_count } = code;
const params = formatCodeParams(code);
---

<div class="rounded border border-gray-200 dark:border-gray-800 p-4 hover:border-gray-400 dark:hover:border-gray-600 transition-colors">
  <div class="flex flex-wrap items-baseline gap-x-2 gap-y-1">
    <a href={`/codes/${slug}`} class="flex items-baseline gap-2">
      <h3 class="font-medium">{name}</h3>
      <span class="text-sm text-gray-500 dark:text-gray-400">{params}</span>
      <span class="text-xs text-gray-400 dark:text-gray-500">{circuit_count} {circuit_count === 1 ? "circuit" : "circuits"}</span>
    </a>
    <div class="ml-auto">
      <TagList tags={tags} baseUrl={baseUrl} />
    </div>
  </div>
</div>
