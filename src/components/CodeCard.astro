---
import TagList from "./TagList.astro";
import type { Code } from "../lib/queries";
import { formatCodeParams } from "../lib/queries";

interface Props {
  code: Code & { tags: string[] };
  baseUrl?: URL;
}

const { code, baseUrl } = Astro.props;
const { name, slug, description, tags } = code;
const params = formatCodeParams(code);
---

<div class="rounded border border-gray-200 dark:border-gray-800 p-4 hover:border-gray-400 dark:hover:border-gray-600 transition-colors">
  <a href={`/codes/${slug}`} class="block">
    <div class="flex items-baseline gap-2 mb-1">
      <h3 class="font-medium">{name}</h3>
      <span class="text-sm text-gray-500 dark:text-gray-400">{params}</span>
    </div>
    {description && <p class="text-sm text-gray-600 dark:text-gray-400 mb-2 line-clamp-2">{description}</p>}
  </a>
  <TagList tags={tags} baseUrl={baseUrl} />
</div>
