---
const SHORTCUTS: { keys: string[]; action: string }[] = [
  { keys: ["j", "↓"], action: "Move down" },
  { keys: ["k", "↑"], action: "Move up" },
  { keys: ["gg", "Home"], action: "Jump to first" },
  { keys: ["G", "End"], action: "Jump to last" },
  { keys: ["l", "→", "Space"], action: "Toggle expand row" },
  { keys: ["h", "←"], action: "Collapse row" },
  { keys: ["Enter"], action: "Open detail page" },
  { keys: ["f"], action: "Toggle favorite (focused row / detail page)" },
  { keys: ["⇧F"], action: "Toggle favorites-only filter" },
  { keys: ["1", "2", "3"], action: "Switch format (STIM / QASM / CIRQ)" },
  { keys: ["c", "y"], action: "Copy active circuit" },
  { keys: ["d"], action: "Download active circuit" },
  { keys: ["⇧D"], action: "Download all on page" },
  { keys: ["Backspace", "b"], action: "Back to parent page" },
  { keys: ["/"], action: "Focus search" },
  { keys: ["?"], action: "Toggle this help" },
  { keys: ["Esc"], action: "Collapse row / close help" },
];
---

<div
  id="keyboard-help"
  class="hidden fixed inset-0 z-50"
  role="dialog"
  aria-modal="true"
  aria-labelledby="keyboard-help-title"
>
  <div
    class="kbd-help-backdrop fixed inset-0 bg-black/40 dark:bg-black/60"
    aria-hidden="true"
  ></div>
  <div class="fixed inset-0 flex items-center justify-center p-4 pointer-events-none">
    <div
      class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg shadow-xl max-w-md w-full p-5 pointer-events-auto max-h-[85vh] overflow-y-auto"
    >
      <div class="flex items-center justify-between mb-3">
        <h2 id="keyboard-help-title" class="text-base font-semibold">Keyboard shortcuts</h2>
        <button
          class="kbd-help-close text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 cursor-pointer focus:outline-none focus:ring-2 focus:ring-blue-500 rounded"
          aria-label="Close help"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <table class="w-full text-sm">
        <tbody class="divide-y divide-gray-200 dark:divide-gray-800">
          {
            SHORTCUTS.map(({ keys, action }) => (
              <tr>
                <td class="py-1.5 pr-4">
                  {keys.map((k, i) => (
                    <>
                      {i > 0 && <span class="mx-1 text-gray-400">/</span>}
                      <kbd class="inline-block min-w-[1.5rem] text-center px-1.5 py-0.5 font-mono text-xs border border-gray-300 dark:border-gray-700 rounded bg-gray-50 dark:bg-gray-800">
                        {k}
                      </kbd>
                    </>
                  ))}
                </td>
                <td class="py-1.5 text-gray-600 dark:text-gray-400">{action}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
      <p class="mt-3 text-xs text-gray-500 dark:text-gray-400">
        Some bindings only apply on listing pages.
      </p>
    </div>
  </div>
</div>

<script>
  import { isInputFocused } from "../lib/dom-helpers";

  const overlay = document.getElementById("keyboard-help");
  if (overlay) {
    const backdrop = overlay.querySelector(".kbd-help-backdrop");
    const closeBtn = overlay.querySelector<HTMLButtonElement>(".kbd-help-close");
    let previouslyFocused: HTMLElement | null = null;

    function isVisible(): boolean {
      return !overlay!.classList.contains("hidden");
    }

    function show(): void {
      // Remember which element the user was on, then move focus into the
      // dialog so it can be dismissed by keyboard and Tab is contained.
      previouslyFocused = document.activeElement instanceof HTMLElement
        ? document.activeElement
        : null;
      overlay!.classList.remove("hidden");
      closeBtn?.focus();
    }

    function hide(): void {
      overlay!.classList.add("hidden");
      // Restore focus to whatever the user was on before opening the help.
      if (previouslyFocused && document.contains(previouslyFocused)) {
        previouslyFocused.focus();
      }
      previouslyFocused = null;
    }

    document.addEventListener(
      "keydown",
      function (e) {
        if (e.key === "Escape" && isVisible()) {
          e.preventDefault();
          // Stop propagation so the keynav script does NOT also close an
          // expanded row beneath the open help overlay. Listening in the
          // capture phase ensures we run before any bubble-phase keynav
          // listener that pages register in their own <script>.
          e.stopImmediatePropagation();
          hide();
          return;
        }
        // Trap Tab inside the modal — only the close button is interactive,
        // so any Tab keeps focus on it rather than leaking to the page.
        if (e.key === "Tab" && isVisible()) {
          e.preventDefault();
          e.stopImmediatePropagation();
          closeBtn?.focus();
          return;
        }
        if (e.key === "?" && !isInputFocused() && !e.metaKey && !e.ctrlKey && !e.altKey) {
          e.preventDefault();
          if (isVisible()) hide();
          else show();
        }
      },
      { capture: true },
    );

    backdrop?.addEventListener("click", hide);
    closeBtn?.addEventListener("click", hide);
  }
</script>
