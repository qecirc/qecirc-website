---
import type { Circuit } from "../lib/queries";
import CodeBlock from "./CodeBlock.astro";

interface Props {
  circuit: Circuit & { tags: string[] };
}

const { circuit } = Astro.props;
---

<div id={circuit.slug} class="rounded border border-gray-200 dark:border-gray-800">
  <button
    class="circuit-toggle w-full text-left px-4 py-3 flex items-center gap-3 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors cursor-pointer"
    data-slug={circuit.slug}
    aria-expanded="false"
  >
    <svg
      class="chevron w-4 h-4 shrink-0 text-gray-400 transition-transform duration-200"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      viewBox="0 0 24 24"
      aria-hidden="true"
    >
      <path d="M9 5l7 7-7 7" />
    </svg>

    <span class="font-medium text-sm">{circuit.name}</span>

    <span class="inline-flex gap-1.5 text-xs shrink-0">
      {circuit.qubit_count != null && (
        <span class="bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 px-1.5 py-0.5 rounded" title="Qubit count">
          Q:{circuit.qubit_count}
        </span>
      )}
      {circuit.depth != null && (
        <span class="bg-green-50 dark:bg-green-900/30 text-green-700 dark:text-green-300 px-1.5 py-0.5 rounded" title="Circuit depth">
          D:{circuit.depth}
        </span>
      )}
      {circuit.gate_count != null && (
        <span class="bg-amber-50 dark:bg-amber-900/30 text-amber-700 dark:text-amber-300 px-1.5 py-0.5 rounded" title="Gate count">
          G:{circuit.gate_count}
        </span>
      )}
    </span>

    <div class="flex flex-wrap gap-1 ml-auto">
      {circuit.tags.map((tag) => (
        <span class="bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 px-1.5 py-0.5 text-xs rounded">
          {tag}
        </span>
      ))}
    </div>
  </button>

  <div class="circuit-detail overflow-hidden transition-[max-height] duration-300 ease-in-out" style="max-height: 0px;">
    <div class="border-t border-gray-200 dark:border-gray-800 px-4 py-4 space-y-3">
      {circuit.description && (
        <p class="text-sm text-gray-600 dark:text-gray-400">{circuit.description}</p>
      )}
      <div class="flex flex-wrap gap-x-6 gap-y-1 text-sm">
        <div>
          <span class="text-gray-500 dark:text-gray-400">Source:</span>{" "}
          {circuit.source.startsWith("http") ? (
            <a
              href={circuit.source}
              class="underline hover:text-gray-900 dark:hover:text-gray-100"
              target="_blank"
              rel="noopener"
            >
              {circuit.source}
            </a>
          ) : (
            <span>{circuit.source}</span>
          )}
        </div>
        <div>
          <span class="text-gray-500 dark:text-gray-400">Format:</span>{" "}
          <span class="uppercase">{circuit.format}</span>
        </div>
      </div>
      <CodeBlock code={circuit.body} label={`${circuit.format.toUpperCase()} Circuit`} />
    </div>
  </div>
</div>

<script>
  function initCircuitRows() {
    document.querySelectorAll(".circuit-toggle").forEach(function (btn) {
      if ((btn as HTMLElement).dataset.initialized) return;
      (btn as HTMLElement).dataset.initialized = "1";

      btn.addEventListener("click", function () {
        const slug = (btn as HTMLElement).dataset.slug!;
        const row = btn.closest("[id]") as HTMLElement;
        const detail = row.querySelector(".circuit-detail") as HTMLElement;
        const chevron = btn.querySelector(".chevron") as HTMLElement;
        const isOpen = detail.style.maxHeight !== "0px";

        if (isOpen) {
          detail.style.maxHeight = "0px";
          chevron.classList.remove("rotate-90");
          btn.setAttribute("aria-expanded", "false");
          if (location.hash === "#" + slug) {
            history.replaceState(null, "", location.pathname + location.search);
          }
        } else {
          // Close any other open rows
          document.querySelectorAll(".circuit-detail").forEach(function (d) {
            if (d !== detail) {
              (d as HTMLElement).style.maxHeight = "0px";
              const otherBtn = (d as HTMLElement).closest("[id]")?.querySelector(".circuit-toggle");
              if (otherBtn) {
                otherBtn.querySelector(".chevron")?.classList.remove("rotate-90");
                otherBtn.setAttribute("aria-expanded", "false");
              }
            }
          });
          detail.style.maxHeight = detail.scrollHeight + "px";
          chevron.classList.add("rotate-90");
          btn.setAttribute("aria-expanded", "true");
          history.replaceState(null, "", "#" + slug);
        }
      });
    });
  }

  function expandFromHash() {
    const hash = location.hash.slice(1);
    if (!hash) return;
    const target = document.getElementById(hash);
    if (!target) return;
    const btn = target.querySelector(".circuit-toggle") as HTMLElement;
    if (btn && btn.getAttribute("aria-expanded") !== "true") {
      btn.click();
      target.scrollIntoView({ behavior: "smooth", block: "start" });
    }
  }

  initCircuitRows();
  expandFromHash();
  window.addEventListener("hashchange", expandFromHash);
</script>
