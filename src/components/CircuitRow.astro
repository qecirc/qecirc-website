---
import type { Circuit, CircuitBody, Tool } from "../types";
import { tagToggleUrl } from "../lib/url";
import { formatCircuitId } from "../lib/queries";
import { buildStimFilename } from "../lib/filename";
import CodeBlock from "./CodeBlock.astro";
import HeartIcon from "./HeartIcon.astro";
import MetricBadge from "./MetricBadge.astro";

interface Props {
  circuit: Circuit & { tags: string[] };
  bodies: CircuitBody[];
  tool?: Tool;
  codeSlug: string;
  currentUrl: URL;
}

const { circuit, bodies, tool, codeSlug, currentUrl } = Astro.props;

const existingTags = currentUrl.searchParams.getAll("tag");
const basePath = `/codes/${codeSlug}`;
const tagUrl = (tag: string) => tagToggleUrl(currentUrl.search, existingTags, tag, basePath);
const selectedTags = new Set(existingTags);
const hasMultipleFormats = bodies.length > 1;
const displayId = formatCircuitId(circuit.qec_id);
const anchorId = String(circuit.qec_id);

const stimFilename = buildStimFilename({
  codeSlug: codeSlug,
  circuitSlug: circuit.slug,
  gateCount: circuit.gate_count,
  twoQubitGateCount: circuit.two_qubit_gate_count,
  depth: circuit.depth,
  qubitCount: circuit.qubit_count,
});
---

<div id={anchorId} class="rounded border border-gray-200 dark:border-gray-800 overflow-x-auto">
  <div
    class="circuit-toggle w-full text-left px-4 py-3 grid min-w-max items-center gap-x-1.5 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors cursor-pointer"
    style="grid-template-columns: var(--circuit-grid);"
    role="button"
    tabindex="0"
    data-qec-id={anchorId}
    aria-expanded="false"
  >
    <svg
      class="chevron w-4 h-4 shrink-0 text-gray-400 transition-transform duration-200"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      viewBox="0 0 24 24"
      aria-hidden="true"
    >
      <path d="M9 5l7 7-7 7" />
    </svg>

    <button
      class="circuit-permalink text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-300 font-mono text-xs shrink-0 cursor-pointer"
      aria-label="Copy link to circuit"
      title="Copy link"
      data-qec-id={anchorId}
    >
      <span class="permalink-label">{displayId}</span>
      <svg class="permalink-check w-3.5 h-3.5 hidden text-green-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M20 6L9 17l-5-5" />
      </svg>
    </button>

    <button
      class="circuit-fav text-gray-300 dark:text-gray-600 hover:text-red-400 dark:hover:text-red-400 cursor-pointer shrink-0"
      data-qec-id={anchorId}
      aria-label="Toggle favorite"
      title="Toggle favorite"
    >
      <HeartIcon class="fav-outline w-3.5 h-3.5" />
      <HeartIcon filled class="fav-filled w-3.5 h-3.5 hidden" />
    </button>

    <span class="text-xs text-center">
      <MetricBadge value={circuit.gate_count} color="amber" title="Gate count" />
    </span>
    <span class="text-xs text-center">
      <MetricBadge value={circuit.two_qubit_gate_count} color="purple" title="Two-qubit gate count" />
    </span>
    <span class="text-xs text-center">
      <MetricBadge value={circuit.depth} color="green" title="Circuit depth" />
    </span>
    <span class="text-xs text-center">
      <MetricBadge value={circuit.qubit_count} color="blue" title="Qubit count" />
    </span>

    <span></span>
    <a href={`/circuits/${circuit.qec_id}`} class="circuit-detail-link font-medium text-sm truncate hover:underline inline-flex items-center gap-1 w-fit">
      {circuit.name}
      <svg class="w-3 h-3 shrink-0 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M9 5l7 7-7 7" />
      </svg>
    </a>

    <div class="flex flex-wrap gap-1 justify-self-end">
      {circuit.tags.map((tag) => (
        <a
          href={tagUrl(tag)}
          class:list={[
            "circuit-tag inline-block rounded px-1.5 py-0.5 text-xs transition-colors",
            selectedTags.has(tag)
              ? "bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900 hover:bg-gray-700 dark:hover:bg-gray-300"
              : "bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-gray-700",
          ]}
        >
          {tag}
        </a>
      ))}
    </div>
  </div>

  <div class="circuit-detail overflow-hidden transition-[max-height] duration-300 ease-in-out" style="max-height: 0px;">
    <div class="border-t border-gray-200 dark:border-gray-800 px-4 py-4 space-y-3">
      <div class="flex flex-wrap items-center gap-x-6 gap-y-1 text-sm">
        <div>
          <span class="text-gray-500 dark:text-gray-400">ID:</span>{" "}
          <button
            class="circuit-id-copy font-mono text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 cursor-pointer"
            title="Copy circuit ID"
            data-qec-id={anchorId}
          >
            <span class="id-label">{displayId}</span>
            <svg class="id-check w-3.5 h-3.5 hidden text-green-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20 6L9 17l-5-5" />
            </svg>
          </button>
        </div>
        <div>
          <span class="text-gray-500 dark:text-gray-400">Source:</span>{" "}
          {circuit.source.startsWith("http") ? (
            <a href={circuit.source} class="underline hover:text-gray-900 dark:hover:text-gray-100" target="_blank" rel="noopener">
              {circuit.source}
            </a>
          ) : (
            <span>{circuit.source}</span>
          )}
        </div>
        {tool && (
          <div>
            <span class="text-gray-500 dark:text-gray-400">Tool:</span>{" "}
            {tool.homepage_url ? (
              <a href={tool.homepage_url} class="underline hover:text-gray-900 dark:hover:text-gray-100" target="_blank" rel="noopener">
                {tool.name} &#x2197;
              </a>
            ) : (
              <span>{tool.name}</span>
            )}
          </div>
        )}
        {(circuit.crumble_url || circuit.quirk_url) && (
          <div class="flex items-center gap-3">
            <span class="text-gray-500 dark:text-gray-400">View in:</span>
            {circuit.crumble_url && (
              <a href={circuit.crumble_url} class="underline hover:text-gray-900 dark:hover:text-gray-100" target="_blank" rel="noopener">
                Crumble &#x2197;
              </a>
            )}
            {circuit.quirk_url && (
              <a href={circuit.quirk_url} class="underline hover:text-gray-900 dark:hover:text-gray-100" target="_blank" rel="noopener">
                Quirk &#x2197;
              </a>
            )}
          </div>
        )}
      </div>

      {circuit.notes && (
        <div class="notes-wrapper">
          <p class="notes-text text-sm text-gray-600 dark:text-gray-400 whitespace-pre-line line-clamp-1">{circuit.notes}</p>
          <button
            class="notes-toggle text-xs text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 cursor-pointer mt-0.5 hidden"
            type="button"
          >
            Show more
          </button>
        </div>
      )}

      {hasMultipleFormats ? (
        <div class="format-switcher">
          <div class="flex gap-1 mb-2">
            {bodies.map((b, i) => (
              <button
                class:list={[
                  "format-tab px-3 py-1 text-xs rounded cursor-pointer transition-colors",
                  i === 0
                    ? "bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900"
                    : "bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-gray-700",
                ]}
                data-format={b.format}
              >
                {b.format.toUpperCase()}
              </button>
            ))}
          </div>
          {bodies.map((b, i) => (
            <div class="format-body" data-format={b.format} style={i === 0 ? "" : "display:none"}>
              <CodeBlock code={b.body} label={`${b.format.toUpperCase()} Circuit`} downloadName={b.format === "stim" ? stimFilename : undefined} source={circuit.source} />
            </div>
          ))}
        </div>
      ) : bodies.length === 1 ? (
        <CodeBlock code={bodies[0].body} label={`${bodies[0].format.toUpperCase()} Circuit`} downloadName={bodies[0].format === "stim" ? stimFilename : undefined} source={circuit.source} />
      ) : (
        <p class="text-sm text-gray-400">No circuit body available.</p>
      )}
    </div>
  </div>
</div>

<script>
  function initCircuitRows() {
    document.querySelectorAll(".circuit-toggle").forEach(function (btn) {
      if ((btn as HTMLElement).dataset.initialized) return;
      (btn as HTMLElement).dataset.initialized = "1";

      btn.addEventListener("click", function (e) {
        if ((e.target as HTMLElement).closest(".circuit-tag")) return;
        if ((e.target as HTMLElement).closest(".circuit-permalink")) return;
        if ((e.target as HTMLElement).closest(".circuit-id-copy")) return;
        if ((e.target as HTMLElement).closest(".circuit-detail-link")) return;
        if ((e.target as HTMLElement).closest(".circuit-fav")) return;
        const qecId = (btn as HTMLElement).dataset.qecId!;
        const row = btn.closest("[id]") as HTMLElement;
        const detail = row.querySelector(".circuit-detail") as HTMLElement;
        const chevron = btn.querySelector(".chevron") as HTMLElement;
        const isOpen = detail.style.maxHeight !== "0px";

        if (isOpen) {
          detail.style.maxHeight = "0px";
          chevron.classList.remove("rotate-90");
          btn.setAttribute("aria-expanded", "false");
          if (location.hash === "#" + qecId) {
            history.replaceState(null, "", location.pathname + location.search);
          }
        } else {
          // Close any other open rows
          document.querySelectorAll(".circuit-detail").forEach(function (d) {
            if (d !== detail) {
              (d as HTMLElement).style.maxHeight = "0px";
              const otherBtn = (d as HTMLElement).closest("[id]")?.querySelector(".circuit-toggle");
              if (otherBtn) {
                otherBtn.querySelector(".chevron")?.classList.remove("rotate-90");
                otherBtn.setAttribute("aria-expanded", "false");
              }
            }
          });
          detail.style.maxHeight = detail.scrollHeight + "px";
          chevron.classList.add("rotate-90");
          btn.setAttribute("aria-expanded", "true");
          history.replaceState(null, "", "#" + qecId);

          // Notes toggle: check overflow after first expand
          const notesText = detail.querySelector(".notes-text") as HTMLElement;
          const notesToggle = detail.querySelector(".notes-toggle") as HTMLButtonElement;
          if (notesText && notesToggle && !notesToggle.dataset.initialized) {
            notesToggle.dataset.initialized = "1";
            requestAnimationFrame(function () {
              if (notesText.scrollHeight > notesText.clientHeight) {
                notesToggle.classList.remove("hidden");
              }
            });
            notesToggle.addEventListener("click", function () {
              const isClamped = notesText.classList.contains("line-clamp-1");
              notesText.classList.toggle("line-clamp-1");
              notesToggle.textContent = isClamped ? "Show less" : "Show more";
              requestAnimationFrame(function () {
                detail.style.maxHeight = detail.scrollHeight + "px";
              });
            });
          }
        }
      });
    });
  }

  // Format switcher logic
  function initFormatSwitchers() {
    document.querySelectorAll(".format-switcher").forEach(function (switcher) {
      const tabs = switcher.querySelectorAll(".format-tab");
      const bodies = switcher.querySelectorAll(".format-body");

      tabs.forEach(function (tab) {
        tab.addEventListener("click", function () {
          const format = (tab as HTMLElement).dataset.format;

          // Update tab styles
          tabs.forEach(function (t) {
            if ((t as HTMLElement).dataset.format === format) {
              t.className = "format-tab px-3 py-1 text-xs rounded cursor-pointer transition-colors bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900";
            } else {
              t.className = "format-tab px-3 py-1 text-xs rounded cursor-pointer transition-colors bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-gray-700";
            }
          });

          // Toggle body visibility
          bodies.forEach(function (b) {
            (b as HTMLElement).style.display = (b as HTMLElement).dataset.format === format ? "" : "none";
          });

          // Recalculate max-height after layout reflow from format switch
          const detail = switcher.closest(".circuit-detail") as HTMLElement;
          if (detail && detail.style.maxHeight !== "0px") {
            requestAnimationFrame(function () {
              detail.style.maxHeight = detail.scrollHeight + "px";
            });
          }
        });
      });
    });
  }

  function expandFromHash() {
    const hash = location.hash.slice(1);
    if (!hash) return;
    const target = document.getElementById(hash);
    if (!target) return;
    const btn = target.querySelector(".circuit-toggle") as HTMLElement;
    if (btn && btn.getAttribute("aria-expanded") !== "true") {
      btn.click();
      target.scrollIntoView({ behavior: "smooth", block: "start" });
    }
  }

  function showCopyCheck(btn: HTMLElement, labelSel: string, checkSel: string) {
    const label = btn.querySelector(labelSel) as HTMLElement;
    const check = btn.querySelector(checkSel) as HTMLElement;
    label.classList.add("hidden");
    check.classList.remove("hidden");
    clearTimeout(Number(btn.dataset.timer));
    btn.dataset.timer = String(setTimeout(function () {
      label.classList.remove("hidden");
      check.classList.add("hidden");
    }, 1500));
  }

  function initPermalinks() {
    document.querySelectorAll<HTMLButtonElement>(".circuit-permalink").forEach(function (btn) {
      if (btn.dataset.initialized) return;
      btn.dataset.initialized = "1";

      btn.addEventListener("click", async function () {
        const qecId = btn.dataset.qecId;
        const url = location.origin + location.pathname + "#" + qecId;
        try {
          await navigator.clipboard.writeText(url);
        } catch {
          return;
        }
        showCopyCheck(btn, ".permalink-label", ".permalink-check");
      });
    });
  }

  function initIdCopy() {
    document.querySelectorAll<HTMLButtonElement>(".circuit-id-copy").forEach(function (btn) {
      if (btn.dataset.initialized) return;
      btn.dataset.initialized = "1";

      btn.addEventListener("click", async function () {
        const qecId = btn.dataset.qecId;
        try {
          await navigator.clipboard.writeText("#" + qecId);
        } catch {
          return;
        }
        showCopyCheck(btn, ".id-label", ".id-check");
      });
    });
  }

  function initFavorites() {
    import("../lib/favorites-client").then(function ({ getFavorites, toggleFavorite }) {
      const favSet = new Set(getFavorites());
      document.querySelectorAll<HTMLButtonElement>(".circuit-fav").forEach(function (btn) {
        if (btn.dataset.favInit) return;
        btn.dataset.favInit = "1";

        const qecId = Number(btn.dataset.qecId);
        const outline = btn.querySelector(".fav-outline") as HTMLElement;
        const filled = btn.querySelector(".fav-filled") as HTMLElement;

        function setFavState(isFav: boolean) {
          outline.classList.toggle("hidden", isFav);
          filled.classList.toggle("hidden", !isFav);
          btn.classList.toggle("text-red-400", isFav);
          btn.classList.toggle("dark:text-red-400", isFav);
          btn.classList.toggle("text-gray-300", !isFav);
          btn.classList.toggle("dark:text-gray-600", !isFav);
        }

        if (favSet.has(qecId)) {
          setFavState(true);
        }

        btn.addEventListener("click", function () {
          setFavState(toggleFavorite(qecId));
        });
      });
    });
  }

  initCircuitRows();
  initFormatSwitchers();
  initPermalinks();
  initIdCopy();
  initFavorites();
  expandFromHash();
  window.addEventListener("hashchange", expandFromHash);
</script>
