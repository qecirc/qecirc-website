---
import type { CircuitBody } from "../types";
import CodeBlock from "./CodeBlock.astro";

interface Props {
  bodies: CircuitBody[];
  stimFilename?: string;
  source?: string;
}

const { bodies, stimFilename, source } = Astro.props;
const hasMultipleFormats = bodies.length > 1;

function downloadNameFor(format: string): string | undefined {
  if (!stimFilename) return undefined;
  return stimFilename.replace(/\.stim$/, `.${format}`);
}
---

{hasMultipleFormats ? (
  <div class="format-switcher">
    <div class="flex gap-0.5 mb-2">
      {bodies.map((b, i) => (
        <button
          class:list={[
            "format-tab px-3 py-1.5 text-xs font-semibold rounded-md cursor-pointer transition-colors",
            i === 0
              ? "bg-gray-100 dark:bg-gray-800 text-gray-900 dark:text-gray-100 ring-1 ring-inset ring-gray-200 dark:ring-gray-700"
              : "text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100",
          ]}
          data-format={b.format}
        >
          {b.format.toUpperCase()}
        </button>
      ))}
    </div>
    {bodies.map((b, i) => (
      <div class="format-body" data-format={b.format} style={i === 0 ? "" : "display:none"}>
        <CodeBlock
          code={b.body}
          label={`${b.format.toUpperCase()} Circuit`}
          downloadName={downloadNameFor(b.format)}
          source={source}
        />
      </div>
    ))}
  </div>
) : bodies.length === 1 ? (
  <CodeBlock
    code={bodies[0].body}
    label={`${bodies[0].format.toUpperCase()} Circuit`}
    downloadName={downloadNameFor(bodies[0].format)}
    source={source}
  />
) : (
  <p class="text-sm text-gray-400">No circuit body available.</p>
)}

<script>
  import { initFormatSwitchers } from "../lib/format-switcher-client";
  initFormatSwitchers();
</script>
