---
import type { TagWithCount, CircuitSort, CircuitSortField } from "../types";
import TagList from "./TagList.astro";

interface Props {
  rawGateCount: string;
  rawTwoQubitGateCount: string;
  rawDepth: string;
  rawQubitCount: string;
  errors: { gate_count: boolean; two_qubit_gate_count: boolean; depth: boolean; qubit_count: boolean };
  hasFilters: boolean;
  focus: string;
  allTags: TagWithCount[];
  selectedTags: string[];
  currentUrl: URL;
  codeSlug: string;
  sort: CircuitSort;
}

const { rawGateCount, rawTwoQubitGateCount, rawDepth, rawQubitCount, errors, hasFilters, focus, allTags, selectedTags, currentUrl, codeSlug, sort } = Astro.props;
const anyError = errors.gate_count || errors.two_qubit_gate_count || errors.depth || errors.qubit_count;
const basePath = `/codes/${codeSlug}`;

function inputClass(hasError: boolean): string {
  const base = "w-24 px-2 py-1 text-sm focus:outline-none bg-transparent";
  return hasError ? `${base} ring-1 ring-red-300` : base;
}

const sortLabels: { field: CircuitSortField; label: string; activeClass: string }[] = [
  { field: "gate_count", label: "Gates", activeClass: "bg-amber-50 dark:bg-amber-900/30 text-amber-700 dark:text-amber-300 border-amber-300 dark:border-amber-700" },
  { field: "two_qubit_gate_count", label: "2Q Gates", activeClass: "bg-purple-50 dark:bg-purple-900/30 text-purple-700 dark:text-purple-300 border-purple-300 dark:border-purple-700" },
  { field: "depth", label: "Depth", activeClass: "bg-green-50 dark:bg-green-900/30 text-green-700 dark:text-green-300 border-green-300 dark:border-green-700" },
  { field: "qubit_count", label: "Qubits", activeClass: "bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 border-blue-300 dark:border-blue-700" },
];

function labelInfo(field: CircuitSortField) {
  const meta = sortLabels.find((s) => s.field === field)!;
  const isActive = sort.field === field;
  const arrow = isActive ? (sort.dir === "desc" ? " \u25BC" : " \u25B2") : "";
  const cls = isActive
    ? `${meta.activeClass} cursor-pointer`
    : "bg-gray-50 dark:bg-gray-800 text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 cursor-pointer";
  return { arrow, cls };
}

function sortToggleUrl(field: CircuitSortField): string {
  const params = new URLSearchParams(currentUrl.search);
  params.delete("focus");
  if (sort.field === field) {
    // Toggle direction
    params.set("sort", field);
    params.set("sort_dir", sort.dir === "desc" ? "asc" : "desc");
  } else {
    // Activate with desc default
    params.set("sort", field);
    params.set("sort_dir", "desc");
  }
  const qs = params.toString();
  return basePath + (qs ? "?" + qs : "");
}

const gateSort = labelInfo("gate_count");
const twoQubitGateSort = labelInfo("two_qubit_gate_count");
const depthSort = labelInfo("depth");
const qubitSort = labelInfo("qubit_count");
---

<form id="circuit-filter" method="GET" action={basePath} class="mb-6 space-y-2 sm:sticky sm:top-0 sm:z-10 bg-white dark:bg-gray-950 sm:border-b sm:border-gray-200 sm:dark:border-gray-800 sm:pb-4 sm:-mb-2"
  data-filter-fields="gate_count,two_qubit_gate_count,depth,qubit_count" data-filter-focus={focus} data-base-path={basePath} data-preserve-sort>
  <div class="flex flex-wrap items-center gap-3">
    <div class="flex items-center gap-1.5 rounded border border-gray-200 dark:border-gray-700 px-1.5 py-0.5">
      <a href={sortToggleUrl("gate_count")} class={`rounded px-1.5 py-0.5 text-xs transition-colors ${gateSort.cls}`}>Gates{gateSort.arrow}</a>
      <input type="text" name="gate_count" value={rawGateCount} class={inputClass(errors.gate_count)} placeholder=">10" aria-label="Filter by gate count" data-filter />
    </div>
    <div class="flex items-center gap-1.5 rounded border border-gray-200 dark:border-gray-700 px-1.5 py-0.5">
      <a href={sortToggleUrl("two_qubit_gate_count")} class={`rounded px-1.5 py-0.5 text-xs transition-colors ${twoQubitGateSort.cls}`}>2Q Gates{twoQubitGateSort.arrow}</a>
      <input type="text" name="two_qubit_gate_count" value={rawTwoQubitGateCount} class={inputClass(errors.two_qubit_gate_count)} placeholder=">5" aria-label="Filter by two-qubit gate count" data-filter />
    </div>
    <div class="flex items-center gap-1.5 rounded border border-gray-200 dark:border-gray-700 px-1.5 py-0.5">
      <a href={sortToggleUrl("depth")} class={`rounded px-1.5 py-0.5 text-xs transition-colors ${depthSort.cls}`}>Depth{depthSort.arrow}</a>
      <input type="text" name="depth" value={rawDepth} class={inputClass(errors.depth)} placeholder="<=5" aria-label="Filter by depth" data-filter />
    </div>
    <div class="flex items-center gap-1.5 rounded border border-gray-200 dark:border-gray-700 px-1.5 py-0.5">
      <a href={sortToggleUrl("qubit_count")} class={`rounded px-1.5 py-0.5 text-xs transition-colors ${qubitSort.cls}`}>Qubits{qubitSort.arrow}</a>
      <input type="text" name="qubit_count" value={rawQubitCount} class={inputClass(errors.qubit_count)} placeholder="7" aria-label="Filter by qubit count" data-filter />
    </div>
    <button
      type="button"
      id="fav-filter-toggle"
      class="rounded px-1.5 py-0.5 text-xs transition-colors bg-gray-50 dark:bg-gray-800 text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 cursor-pointer"
      title="Show favorites only"
    >
      <svg class="w-3 h-3 inline -mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z" />
      </svg>
      Favorites
    </button>
    <div class="ml-auto text-xs" data-filter-status>
      {anyError ? (
        <span data-filter-error class="text-red-500">Invalid filter</span>
      ) : hasFilters && (
        <a href={basePath} class="text-gray-500 hover:text-gray-900 dark:hover:text-gray-100 underline">Clear</a>
      )}
      {!anyError && <span data-filter-error class="text-red-500 hidden">Invalid filter</span>}
    </div>
  </div>

  <TagList tags={allTags} selectedTags={selectedTags} showCount baseUrl={currentUrl} basePath={basePath} />
</form>

<script>
  import { initFilterForm } from "../lib/filter-client";
  import { getFavorites } from "../lib/favorites-client";

  const form = document.getElementById("circuit-filter") as HTMLFormElement;
  if (form) initFilterForm(form);

  const favToggle = document.getElementById("fav-filter-toggle");
  if (favToggle) {
    let active = false;
    const activeClasses = ["bg-red-50", "dark:bg-red-900/30", "text-red-600", "dark:text-red-400", "border-red-300", "dark:border-red-700"];
    const inactiveClasses = ["bg-gray-50", "dark:bg-gray-800", "text-gray-500", "dark:text-gray-400", "hover:bg-gray-100", "dark:hover:bg-gray-700"];

    favToggle.addEventListener("click", function () {
      active = !active;

      // Update button style
      const toAdd = active ? activeClasses : inactiveClasses;
      const toRemove = active ? inactiveClasses : activeClasses;
      favToggle.classList.remove(...toRemove);
      favToggle.classList.add(...toAdd);

      // Get favorites and toggle visibility of circuit rows
      const favSet = new Set(getFavorites());
      document.querySelectorAll("[id] > .circuit-toggle").forEach(function (toggle) {
        const row = toggle.closest("[id]") as HTMLElement;
        if (!row || !row.id || isNaN(Number(row.id))) return;
        const qecId = Number(row.id);
        if (active && !favSet.has(qecId)) {
          row.style.display = "none";
        } else {
          row.style.display = "";
        }
      });
    });
  }
</script>
