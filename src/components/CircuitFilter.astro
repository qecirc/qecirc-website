---
import type { TagWithCount, CircuitSort, CircuitSortField } from "../types";
import { circuitSortToggleUrl } from "../lib/url";
import TagList from "./TagList.astro";

interface Props {
  rawGateCount: string;
  rawTwoQubitGateCount: string;
  rawDepth: string;
  rawQubitCount: string;
  errors: { gate_count: boolean; two_qubit_gate_count: boolean; depth: boolean; qubit_count: boolean };
  hasFilters: boolean;
  focus: string;
  allTags: TagWithCount[];
  selectedTags: string[];
  currentUrl: URL;
  codeSlug: string;
  sort: CircuitSort;
}

const { rawGateCount, rawTwoQubitGateCount, rawDepth, rawQubitCount, errors, hasFilters, focus, allTags, selectedTags, currentUrl, codeSlug, sort } = Astro.props;
const anyError = errors.gate_count || errors.two_qubit_gate_count || errors.depth || errors.qubit_count;
const basePath = `/codes/${codeSlug}`;

function inputClass(hasError: boolean): string {
  const base = "w-24 px-2 py-1 text-sm focus:outline-none bg-transparent";
  return hasError ? `${base} ring-1 ring-red-300` : base;
}

function labelInfo(field: CircuitSortField) {
  const isActive = sort.field === field;
  const arrow = isActive ? (sort.dir === "desc" ? "▼" : "▲") : "";
  const cls = isActive
    ? "text-amber-600 dark:text-amber-400 font-semibold cursor-pointer"
    : "text-gray-600 dark:text-gray-400 font-medium hover:text-gray-900 dark:hover:text-gray-100 cursor-pointer";
  return { arrow, cls };
}

const sortToggleUrl = (field: CircuitSortField) =>
  circuitSortToggleUrl(currentUrl, sort, field, basePath);

const gateSort = labelInfo("gate_count");
const twoQubitGateSort = labelInfo("two_qubit_gate_count");
const depthSort = labelInfo("depth");
const qubitSort = labelInfo("qubit_count");
---

<form id="circuit-filter" method="GET" action={basePath} class="mb-6 space-y-2 sm:sticky sm:top-0 sm:z-10 bg-white dark:bg-gray-950 sm:border-b sm:border-gray-200 sm:dark:border-gray-800 sm:pb-4 sm:-mb-2"
  data-filter-fields="gate_count,two_qubit_gate_count,depth,qubit_count" data-filter-focus={focus} data-base-path={basePath} data-preserve-sort>
  <div class="flex flex-wrap items-center gap-3">
    <div class="flex items-center gap-1.5 rounded border border-gray-300 dark:border-gray-700 px-1.5 py-0.5">
      <a href={sortToggleUrl("gate_count")} class={`px-1 py-0.5 text-xs transition-colors ${gateSort.cls}`}>
        Gates{gateSort.arrow && <span class="ml-0.5 text-[10px] text-gray-500 dark:text-gray-500">{gateSort.arrow}</span>}
      </a>
      <input type="text" name="gate_count" value={rawGateCount} class={inputClass(errors.gate_count)} placeholder=">10" aria-label="Filter by gate count" data-filter />
    </div>
    <div class="flex items-center gap-1.5 rounded border border-gray-300 dark:border-gray-700 px-1.5 py-0.5">
      <a href={sortToggleUrl("two_qubit_gate_count")} class={`px-1 py-0.5 text-xs transition-colors ${twoQubitGateSort.cls}`}>
        2Q Gates{twoQubitGateSort.arrow && <span class="ml-0.5 text-[10px] text-gray-500 dark:text-gray-500">{twoQubitGateSort.arrow}</span>}
      </a>
      <input type="text" name="two_qubit_gate_count" value={rawTwoQubitGateCount} class={inputClass(errors.two_qubit_gate_count)} placeholder=">5" aria-label="Filter by two-qubit gate count" data-filter />
    </div>
    <div class="flex items-center gap-1.5 rounded border border-gray-300 dark:border-gray-700 px-1.5 py-0.5">
      <a href={sortToggleUrl("depth")} class={`px-1 py-0.5 text-xs transition-colors ${depthSort.cls}`}>
        Depth{depthSort.arrow && <span class="ml-0.5 text-[10px] text-gray-500 dark:text-gray-500">{depthSort.arrow}</span>}
      </a>
      <input type="text" name="depth" value={rawDepth} class={inputClass(errors.depth)} placeholder="<=5" aria-label="Filter by depth" data-filter />
    </div>
    <div class="flex items-center gap-1.5 rounded border border-gray-300 dark:border-gray-700 px-1.5 py-0.5">
      <a href={sortToggleUrl("qubit_count")} class={`px-1 py-0.5 text-xs transition-colors ${qubitSort.cls}`}>
        Qubits{qubitSort.arrow && <span class="ml-0.5 text-[10px] text-gray-500 dark:text-gray-500">{qubitSort.arrow}</span>}
      </a>
      <input type="text" name="qubit_count" value={rawQubitCount} class={inputClass(errors.qubit_count)} placeholder="7" aria-label="Filter by qubit count" data-filter />
    </div>
    <div class="text-xs" data-filter-status>
      {anyError ? (
        <span data-filter-error class="text-red-500">Invalid filter</span>
      ) : hasFilters && (
        <a
          href={basePath}
          class="inline-flex items-center gap-1 font-medium text-amber-600 dark:text-amber-400 hover:text-amber-800 dark:hover:text-amber-200"
          title="Clear all active filters"
        >
          <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M6 18L18 6M6 6l12 12" />
          </svg>
          Clear filters
        </a>
      )}
      {!anyError && <span data-filter-error class="text-red-500 hidden">Invalid filter</span>}
    </div>
  </div>

  <TagList tags={allTags} selectedTags={selectedTags} showCount baseUrl={currentUrl} basePath={basePath} />
</form>

<script>
  import { initFilterForm } from "../lib/filter-client";

  const form = document.getElementById("circuit-filter") as HTMLFormElement;
  if (form) initFilterForm(form);
</script>
