---
interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;
---

<nav class="text-sm text-gray-500 dark:text-gray-400 mb-6" aria-label="Breadcrumb">
  <ol class="flex flex-wrap gap-1">
    {items.map((item, i) => (
      <li class="flex items-center gap-1">
        {i > 0 && <span>/</span>}
        {item.href ? (
          <a href={item.href} class="hover:text-gray-900 dark:hover:text-gray-100 underline">{item.label}</a>
        ) : (
          <span class="text-gray-900 dark:text-gray-100">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
