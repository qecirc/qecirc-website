---
---

<div id="search-bar" class="relative">
  <input
    type="text"
    class="search-input w-48 rounded border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 px-3 py-1.5 text-sm placeholder-gray-400 focus:border-gray-400 dark:focus:border-gray-500 focus:outline-none"
    placeholder="Search..."
    aria-label="Search codes, circuits, and tools"
    autocomplete="off"
  />
  <ul class="search-results absolute right-0 top-full mt-1 w-96 rounded border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 shadow-lg hidden z-50 max-h-80 overflow-y-auto">
  </ul>
</div>

<script>
  const container = document.getElementById("search-bar") as HTMLElement;
  const input = container.querySelector("input") as HTMLInputElement;
  const resultsList = container.querySelector("ul") as HTMLUListElement;

  let debounceTimer: ReturnType<typeof setTimeout>;
  let activeIndex = -1;

  function show() {
    resultsList.classList.remove("hidden");
  }

  function hide() {
    resultsList.classList.add("hidden");
    activeIndex = -1;
  }

  function updateActive() {
    const items = resultsList.querySelectorAll("li");
    items.forEach(function (item, i) {
      if (i === activeIndex) {
        item.classList.add("bg-gray-100", "dark:bg-gray-800");
      } else {
        item.classList.remove("bg-gray-100", "dark:bg-gray-800");
      }
    });
  }

  function navigateTo(href: string) {
    window.location.href = href;
  }

  async function doSearch(query: string) {
    if (query.length < 2) {
      hide();
      return;
    }

    const res = await fetch("/api/search?q=" + encodeURIComponent(query));
    const results: { type: string; name: string; slug: string; params: string; tags: string[]; href: string; subtitle?: string }[] = await res.json();

    resultsList.innerHTML = "";
    activeIndex = -1;

    if (results.length === 0) {
      resultsList.innerHTML = '<li class="px-3 py-2 text-sm text-gray-400">No results</li>';
      show();
      return;
    }

    results.forEach(function (item) {
      const li = document.createElement("li");
      li.className = "px-3 py-2 text-sm cursor-pointer hover:bg-gray-100 dark:hover:bg-gray-800";
      li.dataset.slug = item.slug;
      li.dataset.href = item.href;

      const topRow = document.createElement("div");
      topRow.className = "flex items-baseline gap-1.5";

      const nameSpan = document.createElement("span");
      nameSpan.className = "font-medium";
      nameSpan.textContent = item.name;
      topRow.appendChild(nameSpan);

      if (item.params) {
        const paramsSpan = document.createElement("span");
        paramsSpan.className = "text-gray-400";
        paramsSpan.textContent = item.params;
        topRow.appendChild(paramsSpan);
      }

      li.appendChild(topRow);

      const meta: string[] = [];
      meta.push(item.type);
      if (item.subtitle) meta.push(item.subtitle);
      const metaDiv = document.createElement("div");
      metaDiv.className = "text-xs text-gray-400 dark:text-gray-500";
      metaDiv.textContent = meta.join(" · ");
      li.appendChild(metaDiv);

      li.addEventListener("click", function () {
        navigateTo(item.href);
      });

      resultsList.appendChild(li);
    });

    show();
  }

  input.addEventListener("input", function () {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(function () {
      doSearch(input.value.trim());
    }, 200);
  });

  input.addEventListener("keydown", function (e) {
    const items = resultsList.querySelectorAll("li[data-href]");
    if (items.length === 0) return;

    if (e.key === "ArrowDown") {
      e.preventDefault();
      activeIndex = Math.min(activeIndex + 1, items.length - 1);
      updateActive();
    } else if (e.key === "ArrowUp") {
      e.preventDefault();
      activeIndex = Math.max(activeIndex - 1, 0);
      updateActive();
    } else if (e.key === "Enter" && activeIndex >= 0) {
      e.preventDefault();
      const href = (items[activeIndex] as HTMLElement).dataset.href;
      if (href) navigateTo(href);
    } else if (e.key === "Escape") {
      hide();
    }
  });

  document.addEventListener("click", function (e) {
    if (!container.contains(e.target as Node)) {
      hide();
    }
  });
</script>
