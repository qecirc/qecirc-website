---
import type { TagWithCount } from "../types";
import TagList from "./TagList.astro";

interface Props {
  rawN: string;
  rawK: string;
  rawD: string;
  errors: { n: boolean; k: boolean; d: boolean };
  hasFilters: boolean;
  focus: string;
  allTags: TagWithCount[];
  selectedTags: string[];
  currentUrl: URL;
}

const { rawN, rawK, rawD, errors, hasFilters, focus, allTags, selectedTags, currentUrl } = Astro.props;
const anyError = errors.n || errors.k || errors.d;
function inputClass(hasError: boolean): string {
  const base = "w-24 rounded-r border border-l-0 px-2 py-1 text-sm focus:outline-none border-gray-200 dark:border-gray-700 dark:bg-gray-900 focus:border-gray-400 dark:focus:border-gray-500";
  return hasError ? `${base} ring-1 ring-red-300` : base;
}

---

<form id="code-filter" method="GET" action="/" class="mb-6 space-y-2"
  data-filter-fields="n,k,d" data-filter-focus={focus} data-base-path="/">
  <div class="flex flex-wrap items-center gap-3">
    <div class="flex items-center">
      <label for="filter-n" class="rounded-l border border-r-0 border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 px-2 py-1 text-xs text-gray-500 dark:text-gray-400">n</label>
      <input id="filter-n" type="text" name="n" value={rawN} class={inputClass(errors.n)} placeholder=">3,<10" data-filter />
    </div>
    <div class="flex items-center">
      <label for="filter-k" class="rounded-l border border-r-0 border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 px-2 py-1 text-xs text-gray-500 dark:text-gray-400">k</label>
      <input id="filter-k" type="text" name="k" value={rawK} class={inputClass(errors.k)} placeholder=">=2" data-filter />
    </div>
    <div class="flex items-center">
      <label for="filter-d" class="rounded-l border border-r-0 border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 px-2 py-1 text-xs text-gray-500 dark:text-gray-400">d</label>
      <input id="filter-d" type="text" name="d" value={rawD} class={inputClass(errors.d)} placeholder="!=5" data-filter />
    </div>
    <div class="ml-auto text-xs" data-filter-status>
      {anyError ? (
        <span data-filter-error class="text-red-500">Invalid filter</span>
      ) : hasFilters && (
        <a href="/" class="text-gray-500 hover:text-gray-900 dark:hover:text-gray-100 underline">Clear</a>
      )}
      {!anyError && <span data-filter-error class="text-red-500 hidden">Invalid filter</span>}
    </div>
  </div>

  <TagList tags={allTags} selectedTags={selectedTags} showCount baseUrl={currentUrl} basePath="/" />
</form>

<script>
  import { initFilterForm } from "../lib/filter-client";
  const form = document.getElementById("code-filter") as HTMLFormElement;
  if (form) initFilterForm(form);
</script>
