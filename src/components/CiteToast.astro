---
---

<div
  id="cite-toast"
  class="fixed bottom-4 left-1/2 -translate-x-1/2 z-50 max-w-lg w-[calc(100%-2rem)] rounded border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 shadow-lg px-4 py-3 text-sm flex items-start gap-3 transition-all duration-300 translate-y-4 opacity-0 pointer-events-none"
  role="status"
  aria-live="polite"
>
  <span id="cite-toast-msg" class="flex-1"></span>
  <button
    id="cite-toast-close"
    class="shrink-0 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 cursor-pointer"
    aria-label="Dismiss"
  >
    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M18 6L6 18M6 6l12 12" />
    </svg>
  </button>
</div>

<script is:inline>
  (function () {
    const toast = document.getElementById("cite-toast");
    const msg = document.getElementById("cite-toast-msg");
    const closeBtn = document.getElementById("cite-toast-close");
    let timer = 0;

    function hide() {
      clearTimeout(timer);
      toast.classList.add("translate-y-4", "opacity-0", "pointer-events-none");
      toast.classList.remove("translate-y-0", "opacity-100", "pointer-events-auto");
    }

    function show(text, sourceUrl) {
      clearTimeout(timer);
      if (sourceUrl) {
        msg.innerHTML = text + ' <a href="' + sourceUrl + '" target="_blank" rel="noopener" class="underline hover:text-gray-900 dark:hover:text-gray-100">' + sourceUrl + "</a>";
      } else {
        msg.textContent = text;
      }
      toast.classList.remove("translate-y-4", "opacity-0", "pointer-events-none");
      toast.classList.add("translate-y-0", "opacity-100", "pointer-events-auto");
      timer = setTimeout(hide, 5000);
    }

    closeBtn.addEventListener("click", hide);
    window.showCiteToast = show;
  })();
</script>
