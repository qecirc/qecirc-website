---
export const prerender = false;

import Layout from "../../components/Layout.astro";
import CodeBlock from "../../components/CodeBlock.astro";
import MatrixDisplay from "../../components/MatrixDisplay.astro";
import {
  getCircuitByQecId,
  getOriginalForCircuit,
  getBodiesForCircuits,
  getToolsForCircuits,
  formatCircuitId,
} from "../../lib/queries";
import { buildStimFilename } from "../../lib/filename";

const qecId = Number(Astro.params.qec_id);
if (!Number.isInteger(qecId) || qecId < 1) {
  return Astro.rewrite("/404");
}

const circuit = getCircuitByQecId(qecId);
if (!circuit) {
  return Astro.rewrite("/404");
}

const bodiesMap = getBodiesForCircuits([circuit.id]);
const bodies = bodiesMap.get(circuit.id) ?? [];
const toolsMap = getToolsForCircuits([circuit.id]);
const tool = toolsMap.get(circuit.id);
const original = getOriginalForCircuit(circuit.id);

const displayId = formatCircuitId(circuit.qec_id);
const hasMultipleFormats = bodies.length > 1;

const stimFilename = buildStimFilename({
  codeSlug: circuit.code_slug,
  circuitSlug: circuit.slug,
  gateCount: circuit.gate_count,
  twoQubitGateCount: circuit.two_qubit_gate_count,
  depth: circuit.depth,
  qubitCount: circuit.qubit_count,
});

function safeParseMatrix(json: string | null): number[][] | null {
  if (!json) return null;
  try { return JSON.parse(json); } catch { return null; }
}

const origHx = original ? safeParseMatrix(original.original_hx) : null;
const origHz = original ? safeParseMatrix(original.original_hz) : null;
const origLx = original ? safeParseMatrix(original.original_logical_x) : null;
const origLz = original ? safeParseMatrix(original.original_logical_z) : null;
const hasOriginalMatrices = origHx || origHz || origLx || origLz;
---

<Layout title={`${circuit.name} ${displayId}`} description={`Circuit ${displayId} for ${circuit.code_name}`}>
  <a
    href={`/codes/${circuit.code_slug}`}
    class="inline-flex items-center gap-1 text-sm text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 mb-4"
  >
    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M15 19l-7-7 7-7" />
    </svg>
    {circuit.code_name}
  </a>

  <div class="flex flex-wrap items-baseline gap-3 mb-4">
    <h1 class="text-2xl font-bold">{circuit.name}</h1>
    <span class="font-mono text-gray-400 dark:text-gray-500 text-lg">{displayId}</span>
  </div>

  <div class="flex flex-wrap gap-2 mb-4">
    {circuit.gate_count != null && (
      <span class="text-xs bg-amber-50 dark:bg-amber-900/30 text-amber-700 dark:text-amber-300 px-2 py-1 rounded" title="Gate count">
        G: {circuit.gate_count}
      </span>
    )}
    {circuit.two_qubit_gate_count != null && (
      <span class="text-xs bg-purple-50 dark:bg-purple-900/30 text-purple-700 dark:text-purple-300 px-2 py-1 rounded" title="Two-qubit gate count">
        2Q: {circuit.two_qubit_gate_count}
      </span>
    )}
    {circuit.depth != null && (
      <span class="text-xs bg-green-50 dark:bg-green-900/30 text-green-700 dark:text-green-300 px-2 py-1 rounded" title="Circuit depth">
        D: {circuit.depth}
      </span>
    )}
    {circuit.qubit_count != null && (
      <span class="text-xs bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 px-2 py-1 rounded" title="Qubit count">
        Q: {circuit.qubit_count}
      </span>
    )}
  </div>

  <div class="flex flex-wrap items-center gap-x-6 gap-y-1 text-sm mb-4">
    <div>
      <span class="text-gray-500 dark:text-gray-400">Source:</span>{" "}
      {circuit.source.startsWith("http") ? (
        <a href={circuit.source} class="underline hover:text-gray-900 dark:hover:text-gray-100" target="_blank" rel="noopener">
          {circuit.source}
        </a>
      ) : (
        <span>{circuit.source}</span>
      )}
    </div>
    {tool && (
      <div>
        <span class="text-gray-500 dark:text-gray-400">Tool:</span>{" "}
        {tool.homepage_url ? (
          <a href={tool.homepage_url} class="underline hover:text-gray-900 dark:hover:text-gray-100" target="_blank" rel="noopener">
            {tool.name} &#x2197;
          </a>
        ) : (
          <span>{tool.name}</span>
        )}
      </div>
    )}
    {(circuit.crumble_url || circuit.quirk_url) && (
      <div class="flex items-center gap-3">
        <span class="text-gray-500 dark:text-gray-400">View in:</span>
        {circuit.crumble_url && (
          <a href={circuit.crumble_url} class="underline hover:text-gray-900 dark:hover:text-gray-100" target="_blank" rel="noopener">
            Crumble &#x2197;
          </a>
        )}
        {circuit.quirk_url && (
          <a href={circuit.quirk_url} class="underline hover:text-gray-900 dark:hover:text-gray-100" target="_blank" rel="noopener">
            Quirk &#x2197;
          </a>
        )}
      </div>
    )}
  </div>

  {circuit.notes && (
    <p class="text-sm text-gray-600 dark:text-gray-400 whitespace-pre-line mb-4">{circuit.notes}</p>
  )}

  {circuit.tags.length > 0 && (
    <div class="flex flex-wrap gap-1 mb-6">
      {circuit.tags.map((tag) => (
        <span class="inline-block rounded bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 px-1.5 py-0.5 text-xs">
          {tag}
        </span>
      ))}
    </div>
  )}

  <h2 class="text-lg font-semibold mb-2">Circuit</h2>

  {hasMultipleFormats ? (
    <div class="format-switcher mb-6">
      <div class="flex gap-1 mb-2">
        {bodies.map((b, i) => (
          <button
            class:list={[
              "format-tab px-3 py-1 text-xs rounded cursor-pointer transition-colors",
              i === 0
                ? "bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900"
                : "bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-gray-700",
            ]}
            data-format={b.format}
          >
            {b.format.toUpperCase()}
          </button>
        ))}
      </div>
      {bodies.map((b, i) => (
        <div class="format-body" data-format={b.format} style={i === 0 ? "" : "display:none"}>
          <CodeBlock code={b.body} label={`${b.format.toUpperCase()} Circuit`} downloadName={b.format === "stim" ? stimFilename : undefined} source={circuit.source} />
        </div>
      ))}
    </div>
  ) : bodies.length === 1 ? (
    <div class="mb-6">
      <CodeBlock code={bodies[0].body} label={`${bodies[0].format.toUpperCase()} Circuit`} downloadName={bodies[0].format === "stim" ? stimFilename : undefined} source={circuit.source} />
    </div>
  ) : (
    <p class="text-sm text-gray-400 mb-6">No circuit body available.</p>
  )}

  {original && (
    <div class="border-t border-gray-200 dark:border-gray-800 pt-4">
      <button
        id="originals-toggle"
        class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 cursor-pointer"
        aria-expanded="false"
      >
        <svg
          class="originals-chevron w-3.5 h-3.5 shrink-0 transition-transform duration-200"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path d="M9 5l7 7-7 7" />
        </svg>
        Original submission (before canonicalization)
      </button>
      <div id="originals-detail" class="overflow-hidden transition-[max-height] duration-300 ease-in-out" style="max-height: 0px;">
        <div class="mt-3 space-y-4">
          {original?.original_stim && (
            <CodeBlock code={original.original_stim} label="Original STIM Circuit" source={circuit.source} />
          )}
          {hasOriginalMatrices && (
            <div class="grid gap-x-6 gap-y-2 sm:grid-cols-2">
              {origHx && <MatrixDisplay label="Original Hx (X-checks)" matrix={origHx} />}
              {origHz && <MatrixDisplay label="Original Hz (Z-checks)" matrix={origHz} />}
              {origLx && <MatrixDisplay label="Original Logical X" matrix={origLx} />}
              {origLz && <MatrixDisplay label="Original Logical Z" matrix={origLz} />}
            </div>
          )}
        </div>
      </div>
    </div>
  )}
</Layout>

<script>
  // Originals toggle
  const toggle = document.getElementById("originals-toggle");
  const detail = document.getElementById("originals-detail");
  if (toggle && detail) {
    const chevron = toggle.querySelector(".originals-chevron");
    toggle.addEventListener("click", function () {
      const isOpen = detail.style.maxHeight !== "0px";
      if (isOpen) {
        detail.style.maxHeight = "0px";
        chevron?.classList.remove("rotate-90");
        toggle.setAttribute("aria-expanded", "false");
      } else {
        detail.style.maxHeight = detail.scrollHeight + "px";
        chevron?.classList.add("rotate-90");
        toggle.setAttribute("aria-expanded", "true");
      }
    });
  }

  // Format switcher
  document.querySelectorAll(".format-switcher").forEach(function (switcher) {
    const tabs = switcher.querySelectorAll(".format-tab");
    const bodies = switcher.querySelectorAll(".format-body");

    tabs.forEach(function (tab) {
      tab.addEventListener("click", function () {
        const format = (tab as HTMLElement).dataset.format;
        tabs.forEach(function (t) {
          if ((t as HTMLElement).dataset.format === format) {
            t.className = "format-tab px-3 py-1 text-xs rounded cursor-pointer transition-colors bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900";
          } else {
            t.className = "format-tab px-3 py-1 text-xs rounded cursor-pointer transition-colors bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-gray-700";
          }
        });
        bodies.forEach(function (b) {
          (b as HTMLElement).style.display = (b as HTMLElement).dataset.format === format ? "" : "none";
        });
      });
    });
  });
</script>
