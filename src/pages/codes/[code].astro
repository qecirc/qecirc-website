---
export const prerender = false;

import Layout from "../../components/Layout.astro";
import TagList from "../../components/TagList.astro";
import CircuitFilter from "../../components/CircuitFilter.astro";
import CircuitRow from "../../components/CircuitRow.astro";
import CodeMatrices from "../../components/CodeMatrices.astro";
import CollapsibleSection from "../../components/CollapsibleSection.astro";
import HeartIcon from "../../components/HeartIcon.astro";
import {
  getCodeBySlug,
  getTagsFor,
  formatCodeParams,
  hasActiveFilters,
  countCircuitsForCode,
  getCircuitTagsForCode,
  getCircuitsWithBodies,
  getToolsForCircuits,
} from "../../lib/queries";
import { parseCircuitParams } from "../../lib/url";
import { safeParseMatrix } from "../../lib/utils";

const { code: codeSlug } = Astro.params;
const code = getCodeBySlug(codeSlug!);

if (!code) {
  return Astro.rewrite("/404");
}

const tags = getTagsFor("code", code.id);
const params = formatCodeParams(code);

const hx = safeParseMatrix(code.hx);
const hz = safeParseMatrix(code.hz);
const logicalX = safeParseMatrix(code.logical_x);
const logicalZ = safeParseMatrix(code.logical_z);
const h = safeParseMatrix(code.h);
const logical = safeParseMatrix(code.logical);
const hasMatrices = !!(h && logical);

// Parse circuit filter and sort params
const { raw, errors, tags: selectedTags, focus, filters, sort } = parseCircuitParams(Astro.url);

const hasFilters = hasActiveFilters(filters);
const totalCount = countCircuitsForCode(code.id);
const { circuits, bodiesMap } = getCircuitsWithBodies(code.id, filters, sort);
const allCircuitTags = getCircuitTagsForCode(code.id);
const toolsMap = getToolsForCircuits(circuits.map((c) => c.id));

const countLabel = hasFilters
  ? `${circuits.length} of ${totalCount} circuit${totalCount !== 1 ? "s" : ""}`
  : `${totalCount} circuit${totalCount !== 1 ? "s" : ""}`;
---

<Layout title={code.name} description={`Circuits for ${code.name}${params ? ` ${params}` : ""}`}>
  <div class="flex items-baseline flex-wrap gap-x-3.5 gap-y-1 mb-2">
    <h1 class="text-2xl font-bold">
      {code.name} <span class="text-gray-500 dark:text-gray-400 font-normal">{params}</span>
    </h1>
    {code.zoo_url && (
      <a
        href={code.zoo_url}
        class="text-[13px] font-medium text-gray-600 dark:text-gray-400 underline decoration-gray-300 dark:decoration-gray-600 hover:text-gray-900 dark:hover:text-gray-100 hover:decoration-gray-500 dark:hover:decoration-gray-400"
        target="_blank"
        rel="noopener"
      >
        View on QEC Zoo<span class="ml-0.5 opacity-65">&#x2197;</span>
      </a>
    )}
  </div>

  <div class="flex flex-wrap items-center gap-x-4 gap-y-2 mb-4">
    <TagList tags={tags} />
  </div>

  {hasMatrices && h && logical && (
    <div class="mb-6">
      <CollapsibleSection id="matrices" label="Check Matrices & Logical Operators">
        <CodeMatrices
          id="code-matrices"
          n={code.n}
          h={h}
          logical={logical}
          hx={hx}
          hz={hz}
          logicalX={logicalX}
          logicalZ={logicalZ}
        />
      </CollapsibleSection>
    </div>
  )}

  <div class="flex items-baseline justify-between mb-2">
    <h2 class="text-lg font-semibold">Circuits</h2>
    <div class="flex items-center gap-4">
      {circuits.length > 0 && (
        <button
          id="download-all-btn"
          class="flex items-center gap-1 text-[13px] text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 hover:bg-gray-100 dark:hover:bg-gray-800 px-1.5 py-1 rounded-md cursor-pointer"
          data-code-slug={codeSlug}
          title="Download all visible circuits (.stim)"
          aria-label="Download all visible circuits"
        >
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3" />
          </svg>
          <span>{countLabel}</span>
        </button>
      )}
      {circuits.length === 0 && (
        <span class="text-[13px] text-gray-500 dark:text-gray-400 px-1.5 py-1">{countLabel}</span>
      )}
      <button
        type="button"
        id="fav-filter-toggle"
        class="flex items-center gap-1 text-[13px] text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 hover:bg-gray-100 dark:hover:bg-gray-800 px-1.5 py-1 rounded-md cursor-pointer"
        title="Show favorites only"
        aria-pressed="false"
      >
        <HeartIcon class="w-3.5 h-3.5" />
        <span>Favorites</span>
      </button>
    </div>
  </div>

  <CircuitFilter
    rawGateCount={raw.gate_count}
    rawTwoQubitGateCount={raw.two_qubit_gate_count}
    rawDepth={raw.depth}
    rawQubitCount={raw.qubit_count}
    errors={errors}
    hasFilters={hasFilters}
    focus={focus}
    allTags={allCircuitTags}
    selectedTags={selectedTags}
    currentUrl={Astro.url}
    codeSlug={codeSlug!}
    sort={sort}
  />

  {circuits.length === 0 ? (
    <div class="text-center py-8">
      <p class="text-gray-500 dark:text-gray-400 mb-2">No circuits match your filters.</p>
      <a href={`/codes/${codeSlug}`} class="text-sm underline text-gray-500 hover:text-gray-900 dark:hover:text-gray-100">Clear filters</a>
    </div>
  ) : (
    <div>
      <div
        class="sticky top-0 z-10 bg-white dark:bg-gray-950 grid items-center gap-x-1.5 px-4 py-1.5 text-[11px] font-bold tracking-wider uppercase text-gray-500 dark:text-gray-400"
        style="grid-template-columns: var(--circuit-grid);"
      >
        <span></span>
        <span></span>
        <span></span>
        <span class="text-center" title="Gate count">G</span>
        <span class="text-center" title="Two-qubit gate count">2Q</span>
        <span class="text-center" title="Circuit depth">D</span>
        <span class="text-center" title="Qubit count">Q</span>
        <span></span>
        <span>Name</span>
      </div>
      <div class="space-y-2">
        {circuits.map((circuit) => (
          <CircuitRow circuit={circuit} bodies={bodiesMap.get(circuit.id) ?? []} tool={toolsMap.get(circuit.id)} codeSlug={codeSlug!} currentUrl={Astro.url} />
        ))}
      </div>
    </div>
  )}
</Layout>

<script>
  import { getFavorites } from "../../lib/favorites-client";

  const favToggle = document.getElementById("fav-filter-toggle");
  if (favToggle) {
    let active = false;
    favToggle.addEventListener("click", function () {
      active = !active;
      favToggle.setAttribute("aria-pressed", active ? "true" : "false");
      favToggle.classList.toggle("text-red-500", active);
      favToggle.classList.toggle("dark:text-red-400", active);
      favToggle.classList.toggle("text-gray-500", !active);
      favToggle.classList.toggle("dark:text-gray-400", !active);

      const favSet = new Set(getFavorites());
      document.querySelectorAll("[id] > .circuit-toggle").forEach(function (toggle) {
        const row = toggle.closest("[id]") as HTMLElement;
        if (!row || !row.id || isNaN(Number(row.id))) return;
        const qecId = Number(row.id);
        if (active && !favSet.has(qecId)) {
          row.style.display = "none";
        } else {
          row.style.display = "";
        }
      });
    });
  }

  const downloadBtn = document.getElementById("download-all-btn");
  if (downloadBtn) {
    downloadBtn.addEventListener("click", async function () {
      const slug = (downloadBtn as HTMLElement).dataset.codeSlug;
      if (!slug) return;
      const params = new URLSearchParams(window.location.search);
      params.set("code", slug);
      downloadBtn.classList.add("opacity-50", "pointer-events-none");
      try {
        const resp = await fetch(`/api/download?${params}`);
        if (!resp.ok) return;
        const blob = await resp.blob();
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url;
        const disposition = resp.headers.get("Content-Disposition") ?? "";
        const match = disposition.match(/filename="(.+)"/);
        a.download = match ? match[1] : `${slug}_circuits.stim.zip`;
        a.click();
        URL.revokeObjectURL(url);
        if (typeof window.showCiteToast === "function") {
          window.showCiteToast("Please cite the corresponding sources when using these circuits.");
        }
      } finally {
        downloadBtn.classList.remove("opacity-50", "pointer-events-none");
      }
    });
  }
</script>
