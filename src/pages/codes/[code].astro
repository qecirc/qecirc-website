---
export const prerender = false;

import Layout from "../../components/Layout.astro";
import TagList from "../../components/TagList.astro";
import CircuitFilter from "../../components/CircuitFilter.astro";
import CircuitRow from "../../components/CircuitRow.astro";
import MatrixDisplay from "../../components/MatrixDisplay.astro";
import {
  getCodeBySlug,
  getTagsFor,
  formatCodeParams,
  hasActiveFilters,
  filterCircuitsForCode,
  getCircuitsForCode,
  countCircuitsForCode,
  getCircuitTagsForCode,
  getBodiesForCircuits,
  getToolsForCircuits,
} from "../../lib/queries";
import type { CircuitFilters, CircuitSort, CircuitSortField, SortDir } from "../../types";
import { parseFilterParams } from "../../lib/url";

const { code: codeSlug } = Astro.params;
const code = getCodeBySlug(codeSlug!);

if (!code) {
  return Astro.rewrite("/404");
}

const tags = getTagsFor("code", code.id);
const params = formatCodeParams(code);

// Parse matrices from JSON (graceful fallback on malformed data)
function safeParseMatrix(json: string | null): number[][] | null {
  if (!json) return null;
  try { return JSON.parse(json); } catch { return null; }
}
const hx = safeParseMatrix(code.hx);
const hz = safeParseMatrix(code.hz);
const logicalX = safeParseMatrix(code.logical_x);
const logicalZ = safeParseMatrix(code.logical_z);
const hasMatrices = hx || hz || logicalX || logicalZ;

// Parse circuit filter params
const { raw, parsed, errors, tags: selectedTags, focus } = parseFilterParams(Astro.url, ["gate_count", "two_qubit_gate_count", "depth", "qubit_count"] as const);

// Parse sort params
const VALID_SORT_FIELDS = new Set<CircuitSortField>(["qubit_count", "depth", "gate_count", "two_qubit_gate_count"]);
const VALID_SORT_DIRS = new Set<SortDir>(["asc", "desc"]);
const rawSort = Astro.url.searchParams.get("sort") ?? "";
const rawSortDir = Astro.url.searchParams.get("sort_dir") ?? "";
const sort: CircuitSort = VALID_SORT_FIELDS.has(rawSort as CircuitSortField)
  ? { field: rawSort as CircuitSortField, dir: VALID_SORT_DIRS.has(rawSortDir as SortDir) ? rawSortDir as SortDir : "desc" }
  : { field: "gate_count", dir: "desc" };

const filters: CircuitFilters = {
  ...parsed,
  tags: selectedTags.length > 0 ? selectedTags : undefined,
};

const hasFilters = hasActiveFilters(filters);
const totalCount = countCircuitsForCode(code.id);
const circuits = hasFilters ? filterCircuitsForCode(code.id, filters, sort) : getCircuitsForCode(code.id, sort);
const allCircuitTags = getCircuitTagsForCode(code.id);
const circuitIds = circuits.map((c) => c.id);
const bodiesMap = getBodiesForCircuits(circuitIds);
const toolsMap = getToolsForCircuits(circuitIds);

const countLabel = hasFilters
  ? `${circuits.length} of ${totalCount} circuit${totalCount !== 1 ? "s" : ""}`
  : `${totalCount} circuit${totalCount !== 1 ? "s" : ""}`;
---

<Layout title={code.name}>
  <h1 class="text-2xl font-bold mb-2">
    {code.name} <span class="text-gray-500 dark:text-gray-400 font-normal">{params}</span>
  </h1>

  <div class="flex flex-wrap items-center gap-x-4 gap-y-2 mb-4">
    {code.zoo_url && (
      <a href={code.zoo_url} class="text-sm underline text-gray-500 hover:text-gray-900 dark:hover:text-gray-100" target="_blank" rel="noopener">
        QEC Zoo &#x2197;
      </a>
    )}
    <TagList tags={tags} />
  </div>

  {hasMatrices && (
    <div class="mb-6">
      <button
        id="matrices-toggle"
        class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 cursor-pointer"
        aria-expanded="false"
      >
        <svg
          class="matrices-chevron w-3.5 h-3.5 shrink-0 transition-transform duration-200"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path d="M9 5l7 7-7 7" />
        </svg>
        Check Matrices & Logical Operators
      </button>
      <div id="matrices-detail" class="overflow-hidden transition-[max-height] duration-300 ease-in-out" style="max-height: 0px;">
        <div class="mt-3 grid gap-x-6 gap-y-2 sm:grid-cols-2">
          {hx && <MatrixDisplay label="Hx (X-checks)" matrix={hx} />}
          {hz && <MatrixDisplay label="Hz (Z-checks)" matrix={hz} />}
          {logicalX && <MatrixDisplay label="Logical X" matrix={logicalX} />}
          {logicalZ && <MatrixDisplay label="Logical Z" matrix={logicalZ} />}
        </div>
      </div>
    </div>
  )}

  <div class="flex items-baseline justify-between mb-2">
    <h2 class="text-lg font-semibold">Circuits</h2>
    <span class="text-sm text-gray-500 dark:text-gray-400">{countLabel}</span>
  </div>

  <CircuitFilter
    rawGateCount={raw.gate_count}
    rawTwoQubitGateCount={raw.two_qubit_gate_count}
    rawDepth={raw.depth}
    rawQubitCount={raw.qubit_count}
    errors={errors}
    hasFilters={hasFilters}
    focus={focus}
    allTags={allCircuitTags}
    selectedTags={selectedTags}
    currentUrl={Astro.url}
    codeSlug={codeSlug!}
    sort={sort}
  />

  {circuits.length === 0 ? (
    <div class="text-center py-8">
      <p class="text-gray-500 dark:text-gray-400 mb-2">No circuits match your filters.</p>
      <a href={`/codes/${codeSlug}`} class="text-sm underline text-gray-500 hover:text-gray-900 dark:hover:text-gray-100">Clear filters</a>
    </div>
  ) : (
    <div>
      <div
        class="sticky top-0 z-10 bg-white dark:bg-gray-950 grid items-center gap-x-1.5 px-4 py-1.5 text-xs font-medium"
        style="grid-template-columns: var(--circuit-grid);"
      >
        <span></span>
        <span></span>
        <span class="text-center text-amber-700 dark:text-amber-300" title="Gate count">G</span>
        <span class="text-center text-purple-700 dark:text-purple-300" title="Two-qubit gate count">2Q</span>
        <span class="text-center text-green-700 dark:text-green-300" title="Circuit depth">D</span>
        <span class="text-center text-blue-700 dark:text-blue-300" title="Qubit count">Q</span>
        <span></span>
        <span class="text-gray-500 dark:text-gray-400">Name</span>
      </div>
      <div class="space-y-2">
        {circuits.map((circuit) => (
          <CircuitRow circuit={circuit} bodies={bodiesMap.get(circuit.id) ?? []} tool={toolsMap.get(circuit.id)} codeSlug={codeSlug!} currentUrl={Astro.url} />
        ))}
      </div>
    </div>
  )}
</Layout>

<script>
  const toggle = document.getElementById("matrices-toggle");
  const detail = document.getElementById("matrices-detail");
  if (toggle && detail) {
    const chevron = toggle.querySelector(".matrices-chevron");
    toggle.addEventListener("click", function () {
      const isOpen = detail.style.maxHeight !== "0px";
      if (isOpen) {
        detail.style.maxHeight = "0px";
        chevron?.classList.remove("rotate-90");
        toggle.setAttribute("aria-expanded", "false");
      } else {
        detail.style.maxHeight = detail.scrollHeight + "px";
        chevron?.classList.add("rotate-90");
        toggle.setAttribute("aria-expanded", "true");
      }
    });
  }
</script>
