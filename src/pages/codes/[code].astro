---
export const prerender = false;

import Layout from "../../components/Layout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import TagList from "../../components/TagList.astro";
import CircuitFilter from "../../components/CircuitFilter.astro";
import CircuitRow from "../../components/CircuitRow.astro";
import {
  getCodeBySlug,
  getTagsFor,
  formatCodeParams,
  parseFilterString,
  hasActiveCircuitFilters,
  filterCircuitsForCode,
  getCircuitsForCode,
  countCircuitsForCode,
  getCircuitTagsForCode,
  getBodiesForCircuits,
} from "../../lib/queries";
import type { CircuitFilters } from "../../lib/queries";

const { code: codeSlug } = Astro.params;
const code = getCodeBySlug(codeSlug!);

if (!code) {
  return Astro.rewrite("/404");
}

const tags = getTagsFor("code", code.id);
const params = formatCodeParams(code);

// Parse circuit filter params
const rawGateCount = Astro.url.searchParams.get("gate_count") ?? "";
const rawDepth = Astro.url.searchParams.get("depth") ?? "";
const rawQubitCount = Astro.url.searchParams.get("qubit_count") ?? "";
const selectedTags = Astro.url.searchParams.getAll("tag");

const VALID_FOCUS = new Set(["gate_count", "depth", "qubit_count", ""]);
const rawFocus = Astro.url.searchParams.get("focus") ?? "";
const focus = VALID_FOCUS.has(rawFocus) ? rawFocus : "";

const parsedGateCount = rawGateCount ? parseFilterString(rawGateCount) : undefined;
const parsedDepth = rawDepth ? parseFilterString(rawDepth) : undefined;
const parsedQubitCount = rawQubitCount ? parseFilterString(rawQubitCount) : undefined;

const errors = {
  gate_count: rawGateCount !== "" && parsedGateCount === null,
  depth: rawDepth !== "" && parsedDepth === null,
  qubit_count: rawQubitCount !== "" && parsedQubitCount === null,
};

const filters: CircuitFilters = {
  gate_count: parsedGateCount ?? undefined,
  depth: parsedDepth ?? undefined,
  qubit_count: parsedQubitCount ?? undefined,
  tags: selectedTags.length > 0 ? selectedTags : undefined,
};

const hasFilters = hasActiveCircuitFilters(filters);
const totalCount = countCircuitsForCode(code.id);
const circuits = hasFilters ? filterCircuitsForCode(code.id, filters) : getCircuitsForCode(code.id);
const allCircuitTags = getCircuitTagsForCode(code.id);
const bodiesMap = getBodiesForCircuits(circuits.map((c) => c.id));

const countLabel = hasFilters
  ? `${circuits.length} of ${totalCount} circuit${totalCount !== 1 ? "s" : ""}`
  : `${totalCount} circuit${totalCount !== 1 ? "s" : ""}`;
---

<Layout title={code.name}>
  <Breadcrumb items={[
    { label: "Home", href: "/" },
    { label: "Codes", href: "/codes" },
    { label: code.name },
  ]} />

  <h1 class="text-2xl font-bold mb-1">{code.name}</h1>
  <p class="text-gray-500 dark:text-gray-400 mb-4">{params}</p>

  {code.description && <p class="text-gray-600 dark:text-gray-400 mb-4">{code.description}</p>}
  <div class="mb-8">
    <TagList tags={tags} />
  </div>

  <div class="flex items-baseline justify-between mb-2">
    <h2 class="text-lg font-semibold">Circuits</h2>
    <span class="text-sm text-gray-500 dark:text-gray-400">{countLabel}</span>
  </div>

  <CircuitFilter
    rawGateCount={rawGateCount}
    rawDepth={rawDepth}
    rawQubitCount={rawQubitCount}
    errors={errors}
    hasFilters={hasFilters}
    focus={focus}
    allTags={allCircuitTags}
    selectedTags={selectedTags}
    currentUrl={Astro.url}
    codeSlug={codeSlug!}
  />

  {circuits.length === 0 ? (
    <div class="text-center py-8">
      <p class="text-gray-500 dark:text-gray-400 mb-2">No circuits match your filters.</p>
      <a href={`/codes/${codeSlug}`} class="text-sm underline text-gray-500 hover:text-gray-900 dark:hover:text-gray-100">Clear filters</a>
    </div>
  ) : (
    <div class="space-y-2">
      {circuits.map((circuit) => (
        <CircuitRow circuit={circuit} bodies={bodiesMap.get(circuit.id) ?? []} />
      ))}
    </div>
  )}
</Layout>
