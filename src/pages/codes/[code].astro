---
export const prerender = false;

import Layout from "../../components/Layout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import TagList from "../../components/TagList.astro";
import { getCodeBySlug, getFunctionalitiesForCode, getTagsFor, formatCodeParams } from "../../lib/queries";

const { code: codeSlug } = Astro.params;
const code = getCodeBySlug(codeSlug!);

if (!code) {
  return Astro.rewrite("/404");
}

const functionalities = getFunctionalitiesForCode(code.id);
const tags = getTagsFor("code", code.id);
const params = formatCodeParams(code);
---

<Layout title={code.name}>
  <Breadcrumb items={[
    { label: "Home", href: "/" },
    { label: "Codes", href: "/codes" },
    { label: code.name },
  ]} />

  <h1 class="text-2xl font-bold mb-1">{code.name}</h1>
  <p class="text-gray-500 dark:text-gray-400 mb-4">{params}</p>

  {code.description && <p class="text-gray-600 dark:text-gray-400 mb-4">{code.description}</p>}
  <div class="mb-8">
    <TagList tags={tags} />
  </div>

  <h2 class="text-lg font-semibold mb-4">Circuit Functionalities</h2>
  {functionalities.length === 0 ? (
    <p class="text-gray-500">No functionalities yet.</p>
  ) : (
    <div class="grid gap-3">
      {functionalities.map((func) => (
        <a
          href={`/codes/${codeSlug}/${func.slug}`}
          class="block rounded border border-gray-200 dark:border-gray-800 p-4 hover:border-gray-400 dark:hover:border-gray-600 transition-colors"
        >
          <h3 class="font-medium mb-1">{func.name}</h3>
          {func.description && (
            <p class="text-sm text-gray-600 dark:text-gray-400 mb-2">{func.description}</p>
          )}
          <TagList tags={func.tags} />
        </a>
      ))}
    </div>
  )}
</Layout>
