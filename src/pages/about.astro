---
// SSR required while Basic Auth middleware is active (reads request headers).
// Remove this and re-enable prerendering when the middleware is removed.
export const prerender = false;
import Layout from "../components/Layout.astro";
---

<Layout title="About">
  <div class="max-w-2xl">
    <h1 class="text-3xl font-bold mb-4">QECirc</h1>
    <p class="text-gray-600 dark:text-gray-400 mb-6">
      A community-driven library for quantum error correction circuits.
      Browse codes and their circuits, stored in extended STIM format.
    </p>

    <h2 class="text-xl font-semibold mb-3">License</h2>
    <p class="text-gray-600 dark:text-gray-400 mb-2">
      The source code is licensed under the
      <a href="https://opensource.org/licenses/MIT" class="underline text-gray-900 dark:text-gray-100 hover:text-gray-600 dark:hover:text-gray-300" target="_blank" rel="noopener">MIT License</a>.
    </p>
    <p class="text-gray-600 dark:text-gray-400">
      The circuit data is licensed under
      <a href="https://creativecommons.org/licenses/by-sa/4.0/" class="underline text-gray-900 dark:text-gray-100 hover:text-gray-600 dark:hover:text-gray-300" target="_blank" rel="noopener">CC BY-SA 4.0</a>.
    </p>
  </div>
</Layout>
