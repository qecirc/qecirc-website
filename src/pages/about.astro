---
// SSR required while Basic Auth middleware is active (reads request headers).
// Remove this and re-enable prerendering when the middleware is removed.
export const prerender = false;
import Layout from "../components/Layout.astro";
---

<Layout title="About">
  <div class="max-w-2xl">
    <h1 class="text-3xl font-bold mb-4">QECirc</h1>
    <p class="text-gray-600 dark:text-gray-400 mb-6">
      A community-driven library for quantum error correction circuits.
      Browse codes and their circuits, stored in extended STIM format.
    </p>
  </div>
</Layout>
