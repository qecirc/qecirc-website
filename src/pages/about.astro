---
import Layout from "../components/Layout.astro";

const kbdCls =
  "inline-block min-w-[1.25rem] text-center px-1 py-0.5 font-mono text-xs border border-gray-300 dark:border-gray-700 rounded bg-gray-50 dark:bg-gray-800";
---

<Layout title="About" description="About the QECirc project — goals, data model, and how to contribute">
  <div class="max-w-2xl">
    <h1 class="text-3xl font-bold mb-4">QECirc</h1>
    <p class="text-gray-600 dark:text-gray-400 mb-6">
      A community-driven library for quantum error correction circuits.
    </p>

    <h2 class="text-xl font-semibold mb-3">What QECirc is</h2>
    <ul class="list-disc pl-5 text-gray-600 dark:text-gray-400 mb-6 space-y-1">
      <li>A place to find and share reusable quantum error correction circuits</li>
      <li>A fast, simple way to grab standard circuits for common tasks — encoding, state preparation, syndrome extraction, and more</li>
      <li>A hub for the QEC circuit community, highlighting well-crafted circuits and the tools used to create them</li>
      <li>Simple to use and open to everyone</li>
    </ul>

    <h2 class="text-xl font-semibold mb-3">What QECirc is not</h2>
    <ul class="list-disc pl-5 text-gray-600 dark:text-gray-400 mb-6 space-y-1">
      <li>A replacement for the <a href="https://errorcorrectionzoo.org/" class="prose-link" target="_blank" rel="noopener">QEC Zoo</a> — detailed code properties belong there</li>
      <li>An archive for highly specific circuit constructions — those are better stored on platforms like Zenodo, with a link from the Zoo</li>
    </ul>

    <h2 class="text-xl font-semibold mb-3">Keyboard shortcuts</h2>
    <p class="text-gray-600 dark:text-gray-400 mb-3">
      Listing pages support keyboard navigation. Press <kbd class="inline-block min-w-[1.25rem] text-center px-1 py-0.5 font-mono text-xs border border-gray-300 dark:border-gray-700 rounded bg-gray-50 dark:bg-gray-800">?</kbd> anywhere to open the full reference.
    </p>
    <ul class="list-disc pl-5 text-gray-600 dark:text-gray-400 mb-6 space-y-1 text-sm">
      <li>
        <kbd class={kbdCls}>j</kbd> / <kbd class={kbdCls}>k</kbd> or arrow keys to move; <kbd class={kbdCls}>gg</kbd> / <kbd class={kbdCls}>G</kbd> for first / last
      </li>
      <li>
        <kbd class={kbdCls}>l</kbd> / <kbd class={kbdCls}>→</kbd> or <kbd class={kbdCls}>Space</kbd> toggle a circuit row; <kbd class={kbdCls}>h</kbd> / <kbd class={kbdCls}>←</kbd> collapse; <kbd class={kbdCls}>Enter</kbd> opens the detail page
      </li>
      <li>
        <kbd class={kbdCls}>f</kbd> to toggle favorite, <kbd class={kbdCls}>/</kbd> to focus search, <kbd class={kbdCls}>Esc</kbd> to collapse the open row
      </li>
      <li>
        <kbd class={kbdCls}>1</kbd> / <kbd class={kbdCls}>2</kbd> / <kbd class={kbdCls}>3</kbd> switch format on the open circuit; <kbd class={kbdCls}>c</kbd> or <kbd class={kbdCls}>y</kbd> copy, <kbd class={kbdCls}>d</kbd> download; <kbd class={kbdCls}>⇧D</kbd> downloads all on the page
      </li>
      <li>
        <kbd class={kbdCls}>Backspace</kbd> or <kbd class={kbdCls}>b</kbd> goes back to the parent page (from a circuit to its code, from a code page to home)
      </li>
    </ul>

    <h2 id="alpha" class="text-xl font-semibold mb-3">Alpha Status</h2>
    <p class="text-gray-600 dark:text-gray-400 mb-6">
      QECirc is currently in alpha. The site is under active development, which means functionality, URLs, permalinks, and circuit data may change without notice. If you encounter any issues or incorrect data, please <a href="https://github.com/qecirc/qecirc-website/issues" class="prose-link" target="_blank" rel="noopener">open an issue</a> on GitHub.
    </p>

    <h2 class="text-xl font-semibold mb-3">Development</h2>
    <p class="text-gray-600 dark:text-gray-400 mb-2">
      QECirc was created and is maintained by Ludwig Schmid and Tom Peham.
    </p>
    <p class="text-gray-600 dark:text-gray-400 mb-4">
      QECirc is funded by the <a href="https://unitary.foundation" class="prose-link" target="_blank" rel="noopener">Unitary Foundation</a> and supported by the <a href="https://www.cda.cit.tum.de/" class="prose-link" target="_blank" rel="noopener">Chair for Design Automation</a> at the Technical University of Munich.
    </p>
    <a href="https://unitary.foundation" target="_blank" rel="noopener" class="inline-block mb-6">
      <img
        src="https://img.shields.io/badge/Supported%20By-UNITARY%20FOUNDATION-brightgreen.svg?style=for-the-badge"
        alt="Supported by Unitary Foundation"
        height="28"
      />
    </a>

    <h2 class="text-xl font-semibold mb-3">License</h2>
    <p class="text-gray-600 dark:text-gray-400 mb-2">
      The source code is licensed under the
      <a href="https://opensource.org/licenses/MIT" class="prose-link" target="_blank" rel="noopener">MIT License</a>.
    </p>
    <p class="text-gray-600 dark:text-gray-400">
      The circuit data is licensed under
      <a href="https://creativecommons.org/licenses/by-sa/4.0/" class="prose-link" target="_blank" rel="noopener">CC BY-SA 4.0</a>.
    </p>
  </div>
</Layout>
