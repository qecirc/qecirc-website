---
export const prerender = false;

import Layout from "../../components/Layout.astro";
import ToolCard from "../../components/ToolCard.astro";
import TagList from "../../components/TagList.astro";
import {
  getAllTools,
  filterTools,
  getTagsWithCount,
  hasActiveFilters,
} from "../../lib/queries";
import type { ToolFilters } from "../../types";

const selectedTags = Astro.url.searchParams.getAll("tag");

const filters: ToolFilters = {
  tags: selectedTags.length > 0 ? selectedTags : undefined,
};

const hasFilters = hasActiveFilters(filters);
const tools = hasFilters ? filterTools(filters) : getAllTools();
const allTags = getTagsWithCount("tool");
---

<Layout title="Tools" description="Software tools used to create QEC circuits">
  <h1 class="text-2xl font-bold mb-4">Tools</h1>

  <TagList tags={allTags} selectedTags={selectedTags} showCount baseUrl={Astro.url} basePath="/tools" class="mb-6">
    {hasFilters && (
      <a href="/tools" class="text-xs text-gray-500 hover:text-gray-900 dark:hover:text-gray-100 underline ml-2">Clear</a>
    )}
  </TagList>

  {tools.length === 0 ? (
    <div class="text-center py-8">
      <p class="text-gray-500 dark:text-gray-400 mb-2">No tools match your filters.</p>
      <a href="/tools" class="text-sm underline text-gray-500 hover:text-gray-900 dark:hover:text-gray-100">Clear filters</a>
    </div>
  ) : (
    <div class="grid gap-3">
      {tools.map((tool) => (
        <ToolCard tool={tool} baseUrl={Astro.url} />
      ))}
    </div>
  )}
</Layout>
