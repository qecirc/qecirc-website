---
// SSR required while Basic Auth middleware is active (reads request headers).
// Remove this and re-enable prerendering when the middleware is removed.
export const prerender = false;
import Layout from "../components/Layout.astro";
---

<Layout title="Not Found">
  <h1 class="text-2xl font-bold mb-4">Page Not Found</h1>
  <p class="text-gray-600 dark:text-gray-400 mb-4">The page you're looking for doesn't exist.</p>
  <a href="/" class="text-gray-900 dark:text-gray-100 underline hover:no-underline">Go home</a>
</Layout>
