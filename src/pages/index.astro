---
import Layout from "../components/Layout.astro";
---

<Layout title="Home">
  <div class="max-w-2xl">
    <h1 class="text-3xl font-bold mb-4">QECirc</h1>
    <p class="text-gray-600 dark:text-gray-400 mb-6">
      A community-driven library for quantum error correction circuits.
      Browse codes and their circuits, stored in extended STIM format.
    </p>
    <a
      href="/codes"
      class="inline-block rounded bg-gray-900 dark:bg-gray-100 px-4 py-2 text-sm text-white dark:text-gray-900 hover:bg-gray-700 dark:hover:bg-gray-300"
    >
      Browse Codes
    </a>
  </div>
</Layout>
